# Easiest way to configure VRTwin: run the GUI (run.bat on Windows, ./run.sh on
# Linux/macOS) - it edits `.env` for you, explains every option, and has a
# reset-to-defaults button.
# Manual alternative: copy this file to `.env` and fill in your keys.

# --- Required key ---
# One OpenRouter key powers everything (brain, ears, voice):
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...

# --- Models (all via OpenRouter) ---
# The brain (reasoning is disabled in code):
#OPENROUTER_MODEL=anthropic/claude-sonnet-5
# The ears (speech-to-text):
#STT_MODEL=openai/gpt-4o-transcribe
# The voice (text-to-speech):
#TTS_MODEL=google/gemini-3.1-flash-tts-preview
# Let the brain think before replying (slower, more expensive, smarter):
#OPENROUTER_REASONING_ENABLED=false
# Reply randomness. Leave unset to use the model's own default. 0 = deterministic, ~1-1.5 = more varied.
#OPENROUTER_TEMPERATURE=

# --- Audio devices ---
# Run `python main.py --list-devices` to see yours.
# Accepts an index number or a name fragment. Defaults depend on your OS:
#   INPUT_DEVICE  = the cable that carries VRChat's sound TO the bot
#   OUTPUT_DEVICE = the cable that carries the bot's voice TO VRChat
# Windows (VB-CABLE A+B):  INPUT_DEVICE=CABLE-A         OUTPUT_DEVICE=CABLE-B
# macOS   (BlackHole):     INPUT_DEVICE=BlackHole 2ch   OUTPUT_DEVICE=BlackHole 16ch
# Linux   (Pulse/PipeWire): keep both on "pulse" and pick the concrete devices
#                           with PULSE_SOURCE/PULSE_SINK below.
#INPUT_DEVICE=CABLE-A
#OUTPUT_DEVICE=CABLE-B
# Linux only: which source/sink the "pulse" device maps to. ./run.sh creates the
# vrtwin_ears/vrtwin_voice virtual cables. Empty = system default mic/speakers.
#PULSE_SOURCE=vrtwin_ears.monitor
#PULSE_SINK=vrtwin_voice
# Sample rate used to capture audio for voice detection and speech-to-text.
#AUDIO_SAMPLE_RATE=16000

# Voice sensitivity in dB. Closer to 0 = less sensitive (ignores quiet sounds).
#VAD_VOLUME_DB_THRESHOLD=-50
# How long (seconds) of silence marks the end of an utterance.
#VAD_SILENCE_DURATION_THRESHOLD=0.5
# Ignore the bot's own voice coming back through the input device:
#CANCEL_ECHO=true

# --- Voice ---
# Gemini TTS prebuilt voices: Kore, Puck, Zephyr, Charon, Fenrir, Leda, Orus, Aoede, ...
#TTS_VOICE=Kore
# Gemini 3.1 Flash TTS outputs 24 kHz PCM; only change this for a different TTS model.
#TTS_SAMPLE_RATE=24000
#STT_LANGUAGE=en
# Directory to cache synthesized speech (skips re-synthesizing repeated replies). Empty = disabled.
#TTS_CACHE_DIR=
# Network timeouts (seconds) for the STT/TTS requests:
#STT_TIMEOUT=10.0
#TTS_TIMEOUT=30.0
# Audio chunks shorter than this (bytes) are skipped as too short to transcribe:
#STT_MIN_DATA_LENGTH=4096
# HTTP connection pool size, shared by the STT and TTS clients:
#HTTP_MAX_CONNECTIONS=100
#HTTP_MAX_KEEPALIVE_CONNECTIONS=20

# Save every recognized utterance as a WAV file (useful for debugging STT/VAD):
#VOICE_RECORDER_ENABLED=false
#VOICE_RECORDER_DIR=recorded_voices

# SQLite file used for conversation history. Change to run multiple bot instances side by side.
#DB_CONNECTION_STR=aiavatar.db

# --- VRChat OSC ---
#OSC_HOST=127.0.0.1
#OSC_PORT=9000
# Your avatar's synced int parameter that drives the expression animations:
#FACE_OSC_ADDRESS=/avatar/parameters/FaceOSC
# Expression name -> parameter value, must match your avatar's animator (JSON):
#FACES={"neutral": 0, "joy": 1, "angry": 2, "sorrow": 3, "fun": 4, "surprise": 5}
# Key in FACES used as the avatar's default/resting expression:
#FACE_NEUTRAL_KEY=neutral
# Show replies in the VRChat chatbox too:
#CHATBOX_ENABLED=true
# VRChat's chatbox character limit:
#CHATBOX_MAX_LENGTH=144

# --- Character ---
#CHARACTER_NAME=Twin
# Full persona override (one line). Face-tag instructions are appended automatically.
#PERSONA=You are Twin, a cheerful AI avatar in VRChat. Keep replies short and spoken-style.

#DEBUG=false
