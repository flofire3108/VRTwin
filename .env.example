# Copy this file to `.env` and fill in your keys.

# --- Required keys ---
# The brain: get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...
# The ears + voice (Whisper STT and TTS): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Model (Claude Sonnet 5 via OpenRouter, reasoning is disabled in code) ---
#OPENROUTER_MODEL=anthropic/claude-sonnet-5

# --- Audio devices ---
# Run `python main.py --list-devices` to see yours.
# Accepts an index number or a name fragment. With VB-CABLE A+B installed:
#   INPUT_DEVICE  = the cable that carries VRChat's sound TO the bot ("CABLE-A Output")
#   OUTPUT_DEVICE = the cable that carries the bot's voice TO VRChat ("CABLE-B Input")
#INPUT_DEVICE=CABLE-A
#OUTPUT_DEVICE=CABLE-B

# Voice sensitivity in dB. Closer to 0 = less sensitive (ignores quiet sounds).
#VAD_VOLUME_DB_THRESHOLD=-50

# --- Voice ---
# OpenAI TTS voices: alloy, echo, fable, onyx, nova, shimmer, sage, ...
#TTS_VOICE=nova
#TTS_MODEL=tts-1
#STT_LANGUAGE=en

# --- VRChat OSC ---
#OSC_HOST=127.0.0.1
#OSC_PORT=9000
# Your avatar's synced int parameter that drives the expression animations:
#FACE_OSC_ADDRESS=/avatar/parameters/FaceOSC
# Expression name -> parameter value, must match your avatar's animator (JSON):
#FACES={"neutral": 0, "joy": 1, "angry": 2, "sorrow": 3, "fun": 4, "surprise": 5}
# Show replies in the VRChat chatbox too:
#CHATBOX_ENABLED=true

# --- Character ---
#CHARACTER_NAME=Twin
# Full persona override (one line). Face-tag instructions are appended automatically.
#PERSONA=You are Twin, a cheerful AI avatar in VRChat. Keep replies short and spoken-style.

#DEBUG=false
